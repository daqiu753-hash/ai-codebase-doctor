{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/daqiu753-hash/ai-codebase-doctor/docs/report-schema.json",
  "title": "AI Codebase Doctor Report",
  "type": "object",
  "required": ["schemaVersion", "score", "summary", "context", "findings"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "score": { "type": "number", "minimum": 0, "maximum": 100 },
    "summary": {
      "type": "object",
      "required": ["critical", "warning", "info", "total"],
      "properties": {
        "critical": { "type": "number" },
        "warning": { "type": "number" },
        "info": { "type": "number" },
        "total": { "type": "number" }
      }
    },
    "context": {
      "type": "object",
      "required": [
        "rootPath",
        "files",
        "sourceFiles",
        "testFiles",
        "framework",
        "detectedProfile",
        "selectedProfile",
        "options",
        "packageManager"
      ],
      "properties": {
        "rootPath": { "type": "string" },
        "files": { "type": "array", "items": { "type": "string" } },
        "readmePath": { "type": "string" },
        "readmeText": { "type": "string" },
        "packageJsonPath": { "type": "string" },
        "packageJsonText": { "type": "string" },
        "packageJson": { "type": "object" },
        "envExamplePath": { "type": "string" },
        "envExampleText": { "type": "string" },
        "sourceFiles": { "type": "array", "items": { "type": "string" } },
        "testFiles": { "type": "array", "items": { "type": "string" } },
        "framework": { "enum": ["nextjs", "vite", "node", "python", "unknown"] },
        "detectedProfile": {
          "enum": ["auto", "nextjs", "vite", "express", "fastapi", "node", "python", "unknown"]
        },
        "selectedProfile": {
          "enum": ["auto", "nextjs", "vite", "express", "fastapi", "node", "python", "unknown"]
        },
        "options": { "type": "object" },
        "packageManager": { "enum": ["npm", "pnpm", "yarn", "bun", "unknown"] }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "severity", "category", "evidence", "whyItMatters", "suggestedFix"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "severity": { "enum": ["critical", "warning", "info"] },
          "category": { "type": "string" },
          "file": { "type": "string" },
          "line": { "type": "number" },
          "evidence": { "type": "string" },
          "expected": { "type": "string" },
          "actual": { "type": "string" },
          "whyItMatters": { "type": "string" },
          "suggestedFix": { "type": "string" },
          "agentPrompt": { "type": "string" }
        }
      }
    }
  }
}
