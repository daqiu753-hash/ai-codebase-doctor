{
  "name": "ai-codebase-doctor",
  "version": "0.5.0",
  "description": "A CLI that audits AI-generated codebases and tells you why they won't run.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ai-codebase-doctor": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md",
    "LICENSE",
    "CHANGELOG.md",
    "docs/checks.md",
    "docs/ci.md",
    "docs/known-limitations.md",
    "docs/profiles.md",
    "docs/report-schema.md",
    "docs/report-schema.json"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "start": "node dist/cli.js",
    "test": "vitest run tests/*.test.ts",
    "test:watch": "vitest tests/*.test.ts",
    "typecheck": "tsc --noEmit",
    "doctor:example": "tsx src/cli.ts examples/ai-generated-fake-saas --out reports"
  },
  "keywords": [
    "ai",
    "codebase",
    "doctor",
    "cli",
    "codex",
    "cursor",
    "claude-code",
    "vibe-coding",
    "static-analysis",
    "ai-generated-code",
    "repo-audit",
    "developer-tools",
    "ci",
    "nextjs",
    "vite",
    "express",
    "fastapi"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daqiu753-hash/ai-codebase-doctor.git"
  },
  "bugs": {
    "url": "https://github.com/daqiu753-hash/ai-codebase-doctor/issues"
  },
  "homepage": "https://github.com/daqiu753-hash/ai-codebase-doctor#readme",
  "dependencies": {
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
